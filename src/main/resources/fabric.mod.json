{
	"schemaVersion": 1,
	"id": "no-render",
	"version": "${version}",

	"name": "No Render",
	"description": "Disables rendering for specific entities and block entities.",
	"authors": [
		"I-No-oNe"
	],
	"contact": {
		"homepage": "https://i-no-one.github.io/",
		"sources": "https://github.com/I-No-oNe/No-Render"
	},

	"license": "MIT",
	"icon": "assets/no-render/icon.png",

	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"adapter": "kotlin",
				"value": "net.i_no_am.render.NoRenderClient"
			}
		]
	},
	"mixins": [
		"no-render.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": ">=26.2",
		"java": ">=25",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}